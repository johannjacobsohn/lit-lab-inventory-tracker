    "docker-run": "docker run -p 8081:8081 lit-frontend"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,jsx}": "eslint --cache --fix"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.0",
    "bootstrap": "^5.3.3",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.5",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.1",
    "react-icons": "^5.3.0",
    "react-redux": "^9.1.2",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^7.0.0",
    "swr": "^2.2.5",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.0.0",
    "@stylistic/eslint-plugin-jsx": "^4.0.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-router-bootstrap": "^0.26.6",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "husky": "^9.1.6",
    "jsdom": "^29.0.0",
    "lint-staged": "^17.0.0",
    "postcss": "^8.5.10",
    "postcss-simple-vars": "^7.0.1",
    "sass": "^1.80.5",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.12.2",
    "vite": "^8.0.0",
    "vite-plugin-mkcert": "^2.0.0",
    "vitest": "^4.1.7"
